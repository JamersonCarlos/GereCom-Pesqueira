# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── GereCom Pesqueira — Backend ────────────────────────────────────────────────

# Imagem (docker-compose)
GITHUB_OWNER=seu-usuario-ou-org
GITHUB_REPO=GereCom-PesqueiraProd
IMAGE_TAG=latest

# Domínio da API (Traefik)
API_HOST=api.seudominio.com.br

# Banco de dados MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=gerecom
DB_PASSWORD=senha_forte_aqui
DB_NAME=gerecom_pesqueira

# JWT
JWT_SECRET=chave_jwt_muito_secreta_aqui
JWT_EXPIRES_IN=7d

# SMTP (e-mail)
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=senha_smtp_aqui
SMTP_FROM="GereCom Pesqueira <noreply@seudominio.com.br>"

